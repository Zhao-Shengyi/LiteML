! html5
html[lang=zh-CN]
  head
    meta[charset=UTF-8]
    meta[name=viewport][content=width=device-width, initial-scale=1.0]
    title LiteML 测试页面

  body
    ! 这是一个注释
    header.nav
      h1.logo MySite
      nav
        a[href=/] 首页
        a[href=/about] 关于
        a.active[href=/contact] 联系我们

    main#content
      section.hero
        h2 欢迎来到 LiteML
        p.intro 这是一种为新手设计的极简 HTML 预处理器语法

      ! 特性列表
      section.features@waterfall(cols=3, gap=16px)
        div.card
          h3 ✅ 无需闭合标签
          p 缩进自动处理
        div.card
          h3 ✅ CSS 选择器语法
          p class 和 id 直接写
        div.card
          h3 ✅ 一键编译
          p 输出标准 HTML

    footer
      p &copy; 2026 LiteML Project

    @js(app.js | defer)
