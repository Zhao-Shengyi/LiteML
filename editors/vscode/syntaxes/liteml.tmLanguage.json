{
  "scopeName": "source.liteml",
  "name": "LiteML",
  "fileTypes": [".lite"],
  "patterns": [
    { "include": "#doctype" },
    { "include": "#comments" },
    { "include": "#raw-html-block" },
    { "include": "#php-block" },
    { "include": "#code-block" },
    { "include": "#long-text" },
    { "include": "#raw-html-line" },
    { "include": "#line-content" }
  ],
  "repository": {

    "doctype": {
      "match": "^(\\s*)(!\\s+html5)\\b",
      "captures": {
        "2": { "name": "keyword.control.doctype" }
      }
    },

    "comments": {
      "match": "^(\\s*)(@\\s+.*)$",
      "captures": {
        "2": { "name": "comment.line" }
      }
    },

    "raw-html-block": {
      "begin": "^(\\s*)(@raw)\\s*$",
      "end": "^(\\s*)(@endraw)\\s*$",
      "beginCaptures": {
        "2": { "name": "keyword.control" }
      },
      "endCaptures": {
        "2": { "name": "keyword.control" }
      },
      "patterns": [
        { "match": ".*", "name": "markup.raw" }
      ]
    },

    "php-block": {
      "begin": "^(\\s*)(@php)\\s*$",
      "end": "^(\\s*)(@endphp)\\s*$",
      "beginCaptures": {
        "2": { "name": "keyword.control.php" }
      },
      "endCaptures": {
        "2": { "name": "keyword.control.php" }
      },
      "patterns": [
        { "match": ".*", "name": "source.php.embedded" }
      ]
    },

    "code-block": {
      "begin": "```(\\w*)\\s*$",
      "end": "^```\\s*$",
      "beginCaptures": {
        "1": { "name": "string.other" }
      },
      "patterns": [
        { "match": ".*", "name": "markup.code" }
      ]
    },

    "long-text": {
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "patterns": [
        { "match": ".*", "name": "string.quoted.triple" }
      ]
    },

    "raw-html-line": {
      "match": "^(\\s*)(<.*)$",
      "captures": {
        "2": { "name": "markup.raw.html" }
      }
    },

    "line-content": {
      "patterns": [
        { "include": "#variables" },
        { "include": "#php-directives" },
        { "include": "#macros" },
        { "include": "#layout-directives" },
        { "include": "#interaction-directives" },
        { "include": "#behavior-directives" },
        { "include": "#use-component" },
        { "include": "#tags" }
      ]
    },

    "variables": {
      "patterns": [
        {
          "begin": "\\{\\{",
          "end": "\\}\\}",
          "name": "variable.other.php",
          "patterns": [
            { "match": "[^}]+", "name": "source.php.embedded" }
          ]
        },
        {
          "begin": "\\{!!",
          "end": "!!\\}",
          "name": "variable.other.php",
          "patterns": [
            { "match": "[^!}]+", "name": "source.php.embedded" }
          ]
        }
      ]
    },

    "php-directives": {
      "patterns": [
        {
          "match": "(@if|@elseif|@else|@endif|@foreach|@endforeach|@while|@endwhile|@for|@endfor|@include|@php|@endphp)\\b",
          "name": "keyword.control.php"
        },
        {
          "match": "\\([^)]*\\)",
          "name": "meta.arguments"
        }
      ]
    },

    "macros": {
      "patterns": [
        {
          "match": "(@audio|@video|@embed|@icon|@css|@js)\\b",
          "name": "support.function"
        },
        {
          "match": "\\([^)]*\\)",
          "name": "meta.arguments"
        }
      ]
    },

    "layout-directives": {
      "patterns": [
        {
          "match": "@(flex|grid|waterfall|position|transition|hide)(!?)\\b",
          "name": "support.type",
          "captures": {
            "2": { "name": "keyword.operator" }
          }
        },
        {
          "match": "\\([^)]*\\)",
          "name": "meta.arguments"
        }
      ]
    },

    "interaction-directives": {
      "patterns": [
        {
          "match": "@(modal|theme-toggle|like)(!?)\\b",
          "name": "support.type",
          "captures": {
            "2": { "name": "keyword.operator" }
          }
        },
        {
          "match": "\\([^)]*\\)",
          "name": "meta.arguments"
        }
      ]
    },

    "use-component": {
      "match": "^\\s*(@use)\\s+([\\w-]+)",
      "captures": {
        "1": { "name": "keyword.control" },
        "2": { "name": "support.class.component" }
      }
    },

    "behavior-directives": {
      "patterns": [
        {
          "match": "(\\[\\*)(required|email|url|minlength|maxlength|range|pattern)(=?)([^\\]]*)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition" },
            "2": { "name": "entity.other.attribute-name" },
            "3": { "name": "keyword.operator.assignment" },
            "4": { "name": "string.quoted" },
            "5": { "name": "punctuation.definition" }
          }
        },
        {
          "match": "\\[\\*[^\\]]*\\]",
          "name": "entity.other.attribute-name"
        }
      ]
    },

    "tags": {
      "patterns": [
        {
          "match": "(?<![@\\w])([a-zA-Z_][\\w-]*)(?=[.#\\[]|\\s|$|![\\w(])",
          "name": "entity.name.tag"
        },
        {
          "match": "#([a-zA-Z_][\\w-]*)",
          "name": "entity.other.attribute.id"
        },
        {
          "match": "\\.([a-zA-Z_][\\w-]*)",
          "name": "entity.other.attribute.class"
        },
        {
          "match": "\\[([\\w-]+)\\s*(=)\\s*([^\\]]*)\\s*\\]",
          "captures": {
            "1": { "name": "entity.other.attribute-name" },
            "2": { "name": "keyword.operator.assignment" },
            "3": { "name": "string.quoted" }
          }
        },
        {
          "match": "\\[[^\\]]*\\]",
          "name": "entity.other.attribute-name"
        }
      ]
    }

  }
}
