{
  "comments": {
    "lineComment": "! "
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"\"\"", "\"\"\""],
    ["```", "```"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "\"\"\"", "close": "\"\"\"" },
    { "open": "```", "close": "```" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[a-zA-Z_][\\w-]*(?:[.#\\[][^\\]]*)*\\s*$",
    "decreaseIndentPattern": "^\\s*@(?:end\\w+|else(?:if)?)\\b"
  }
}
